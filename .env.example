# ── LLM Provider ──────────────────────────────────────────
LLM_PROVIDER=anthropic          # anthropic | openai | ollama
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514

# ── Watch Folder ──────────────────────────────────────────
WATCH_DIR=~/carson-workspace    # Absolute or ~-relative path

# ── Service ───────────────────────────────────────────────
LOG_LEVEL=info                  # debug | info | warn | error
SERVICE_PORT=7780               # Local HTTP port for health/status

# ── Cron / Scheduling ────────────────────────────────────
POLL_INTERVAL_SECONDS=300       # How often to poll external services
CRON_ENABLED=true

# ── External Services (add as needed) ────────────────────
# GITHUB_TOKEN=
# SLACK_WEBHOOK_URL=
# CUSTOM_API_BASE_URL=
# CUSTOM_API_KEY=
