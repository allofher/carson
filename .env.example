# ── API Keys (secrets only — provider selection lives in config.json) ──

# Anthropic
CARSON_ANTHROPIC_API_KEY=

# OpenAI
CARSON_OPENAI_API_KEY=

# Google Gemini
CARSON_GEMINI_API_KEY=

# Ollama needs no key — just set llm_base_url in config.json if not localhost:11434

# ── Overrides (optional — these override config.json values) ──
# CARSON_BRAIN_DIR=
# CARSON_LOG_LEVEL=
# CARSON_DAEMON_PORT=
# CARSON_LOG_DIR=
# CARSON_LLM_PROVIDER=
# CARSON_LLM_MODEL=
# CARSON_LLM_BASE_URL=
# CARSON_SYSTEM_PROMPT_PATH=

# ── External Services ────────────────────────────────────
# GITHUB_TOKEN=
# SLACK_WEBHOOK_URL=
