# ── Watch Folder ──────────────────────────────────────────
CARSON_BRAIN_DIR=~/brain        # Absolute or ~-relative path

# ── Service ───────────────────────────────────────────────
CARSON_LOG_LEVEL=info           # debug | info | warn | error

# ── LLM Provider ─────────────────────────────────────────
CARSON_LLM_PROVIDER=anthropic   # anthropic | openai | ollama
CARSON_LLM_API_KEY=

# ── External Services (add as needed) ────────────────────
# GITHUB_TOKEN=
# SLACK_WEBHOOK_URL=
